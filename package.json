{
  "name": "markdownlive",
  "version": "1.2.0",
  "description": "A simple markdown editor with live WYSIWYG preview",
  "main": "main.js",
  "scripts": {
    "build:renderer": "esbuild src/renderer.js --bundle --outfile=dist/renderer.bundle.js --format=iife --platform=browser --loader:.css=css --loader:.woff=file --loader:.woff2=file --loader:.ttf=file --loader:.eot=file --loader:.svg=file --asset-names=[name]-[hash]",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "postinstall": "npm run rebuild:native",
    "prestart": "npm run build:renderer",
    "start": "electron .",
    "predist:mac": "npm run build:renderer",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.5.0",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0"
  },
  "build": {
    "appId": "com.russellashby.markdownlive",
    "productName": "MarkdownLive",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": null
    }
  }
}
